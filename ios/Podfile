source 'https://github.com/CocoaPods/Specs.git'  # 💡 Use git source to avoid CDN issues

platform :ios, '15.2'

ENV['RCT_NEW_ARCH_ENABLED'] = '0'  # Ensure old architecture

require Pod::Executable.execute_command('node', ['-p',
  'require.resolve("react-native/scripts/react_native_pods.rb", {paths: [process.argv[1]]})',
  __dir__]).strip

prepare_react_native_project!

use_frameworks! :linkage => :static

target 'Luxury_Life' do
  config = use_native_modules!

  # ✅ Permissions
  require_relative '../node_modules/react-native-permissions/scripts/setup.rb'
  setup_permissions([
    'Camera',
    'Microphone',
    'LocationWhenInUse',
    'Notifications'
  ])

  # ✅ React Native core + Hermes
  use_react_native!(
    :path => config[:reactNativePath],
    :app_path => "#{Pod::Config.instance.installation_root}/..",
    :fabric_enabled => false,   # Old architecture
    :hermes_enabled => true     # Hermes enabled
  )

  # ✅ Additional pods
  pod 'GoogleUtilities', :modular_headers => true
  pod 'FirebaseCoreInternal', :modular_headers => true
  pod 'GoogleMaps'
  pod 'Firebase/Analytics'
  pod 'Firebase/Messaging'

  target 'Luxury_LifeTests' do
    inherit! :complete
  end

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false
    )

    installer.pods_project.targets.each do |target|
      # Swift + modular headers setup
      if ['AppAuth', 'GTMAppAuth', 'GoogleUtilities', 'FirebaseCoreInternal'].include?(target.name)
        target.build_configurations.each do |config|
          config.build_settings['DEFINES_MODULE'] = 'YES'
          config.build_settings['BUILD_LIBRARY_FOR_DISTRIBUTION'] = 'YES'
          config.build_settings['SWIFT_VERSION'] = '5.9'
          config.build_settings['OTHER_SWIFT_FLAGS'] ||= ['']
          config.build_settings['OTHER_SWIFT_FLAGS'] << '-enable-experimental-feature'
          config.build_settings['OTHER_SWIFT_FLAGS'] << 'AccessLevelOnImport'
        end
      end

      # Force Hermes dSYM generation
      if target.name.include?("hermes")
        target.build_configurations.each do |config|
          config.build_settings['DEBUG_INFORMATION_FORMAT'] = 'dwarf-with-dsym'
        end
      end
    end
  end
end
